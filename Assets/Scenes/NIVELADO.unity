      value: 90
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: name
      value: Maofis, el pesquero
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.size
      value: 4
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[0]
      value: "Nada. \xBFQu\xE9 me esperaba estando por esta zona?"
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[1]
      value: "\xA1A ver, no me quejo! Pescar estoy pescando, pero\u2026"
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[2]
      value: "\xA1Los peces me salen congelados! No se pueden comer."
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[3]
      value: "Si ya me lo dijo mi hermano mayor. \xBFLe conoces?"
      objectReference: {fileID: 0}
    m_RemovedComponents: []
    m_RemovedGameObjects: []
    m_AddedGameObjects: []
    m_AddedComponents: []
  m_SourcePrefab: {fileID: 100100000, guid: db6828e52ecdccc4db2f84ba46e55a4f, type: 3}
