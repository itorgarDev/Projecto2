    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: name
      value: Qiupez, el pescador
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.size
      value: 4
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[0]
      value: "\xA1Otro! \xA1Ha picado otro!"
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[1]
      value: "Madre m\xEDa, que gusto da pescar por estas tierras."
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[2]
      value: "Me pregunto c\xF3mo le ir\xE1 a mi hermanito. Se fue a probar suerte
        al norte."
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[3]
      value: "Aunque con el fr\xEDo que har\xE1 all\xED, dudo que pique algo."
      objectReference: {fileID: 0}
