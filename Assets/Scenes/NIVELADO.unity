      propertyPath: name
      value: Quibing, el friolero
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[0]
      value: "\xBFY qu\xE9 quieres que le haga? \xA1Yo estoy congelado!"
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[1]
      value: "Ojal\xE1 tener suficientes w\xE9ns para mudarme a la gran aldea."
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[2]
      value: "A ver si viene alg\xFAn cliente."
      objectReference: {fileID: 0}
