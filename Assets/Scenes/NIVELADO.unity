      propertyPath: m_LocalEulerAnglesHint.z
      value: 90
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: name
      value: Maostiao, el guerrero
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.size
      value: 5
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[0]
      value: "\xA1Maostiao para servirles! Bien, ni\xF1o, \xBFa qu\xE9 vienes? \xBFAcaso
        Mao-Qiu te ha enviado a entrenar? Muy bien."
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[1]
      value: "El mundo afuera es agresivo y es peligroso ir desnudo. \xA1Toma esta
        arma!"
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[2]
      value: '[HAS RECIBIDO UN ARMA]'
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[3]
      value: "Ahora, \xBFves ese maniqu\xED de ah\xED? Prueba a blandir tu arma.
        \xA1No tengas piedad con \xE9l! \xA1Como si aplastases a un ratoncito!"
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[4]
      value: "[USA EL RAT\xD3N PARA ATACAR]"
      objectReference: {fileID: 0}
    - target: {fileID: 5858030904094289231, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: m_LocalPosition.x
      value: 0
