        type: 3}
      propertyPath: m_LocalEulerAnglesHint.y
      value: -136.006
      objectReference: {fileID: 0}
    - target: {fileID: 5343600079338238275, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: m_LocalEulerAnglesHint.z
      value: 90
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: name
      value: Mao-Qiu, el sabio
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.size
      value: 2
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[0]
      value: "\xA1Maostiao! Que alegr\xEDa verte. Es uno de los guerreros del pueblo.
        Somos criaturas pac\xEDficas, pero ya se sabe: si quieres la paz, prep\xE1rate
        para la guerra."
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[1]
      value: "\xA1Habla con \xE9l! A ver qu\xE9 te dice."
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[2]
      value: 
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[3]
      value: "Quiz\xE1s puedas ayudarnos. \xBFQu\xE9 dices si lo hablamos con un
        trote? \r\n\xA1Eso es! Vamos a calentar los motores. \xA1A Sacudir esas dos
