      propertyPath: name
      value: Quihuo, el caluroso
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[0]
      value: "\xA1Mequetrefe! \xBFC\xF3mo se te puede ocurrir semejante estupidez?"
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[1]
      value: "Mira que a qui\xE9n se le ocurre vender abrigos de piel. No ser\xEDa
        una mala idea\u2026\t"
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[2]
      value: "\xA1Si no fuese porque todos somos peluditos!"
      objectReference: {fileID: 0}
