      propertyPath: m_LocalEulerAnglesHint.y
      value: -136.006
      objectReference: {fileID: 0}
    - target: {fileID: 5343600079338238275, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: m_LocalEulerAnglesHint.z
      value: 90
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: name
      value: "Baihu, el Guardi\xE1n del Oeste"
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.size
      value: 5
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[0]
      value: "\xA1Hola! \xBFHas venido a jugar conmigo?"
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[1]
      value: "Serpiente: (No es un amigo, Baihu. \xBFNo te has dado cuenta? \xA1Es
        un claro!.)"
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[2]
      value: "Serpiente: (\xA1Quiere quitarnos el amuleto! \xA1Quiere quitarte la
        diversi\xF3n! )"
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[3]
      value: "\xBFQU\xC9? \xA1Eso no lo permitir\xE9! \xA1Vete de aqu\xED o enfr\xE9ntate
        a m\xED!"
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[4]
      value: "Serpiente: (S\xED, muy bien. \xA1Acaba con \xE9l!)"
      objectReference: {fileID: 0}
    m_RemovedComponents: []
    m_RemovedGameObjects: []
    m_AddedGameObjects: []
    m_AddedComponents: []
