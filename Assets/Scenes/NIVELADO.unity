      propertyPath: m_LocalEulerAnglesHint.y
      value: -136.006
      objectReference: {fileID: 0}
    - target: {fileID: 5343600079338238275, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: m_LocalEulerAnglesHint.z
      value: 90
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: name
      value: Mao-Qiu, el sabio
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.size
      value: 5
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[0]
      value: "\xA1Wow! Perdona, no quer\xEDamos despertaros. Es que\u2026 Jam\xE1s
        hab\xEDamos visto una criatura igual. Mira que un color ya es mucho, \xBFpero
        dos? \xA1Wow!\r\n"
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[1]
      value: "En fin, qu\xE9 modales los m\xEDos. Mi nombre es Mao-Qiu y soy el sabio
        de mi tribu. \r\n"
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[2]
      value: Tras comenzar la guerra, nos desterraron y desde entonces estamos en
        busca del balance y las vibras positivas.
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[3]
      value: "Quiz\xE1s puedas ayudarnos. \xBFQu\xE9 dices si lo hablamos con un
        trote? \r\n\xA1Eso es! Vamos a calentar los motores. \xA1A Sacudir esas dos
        patitas!"
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[4]
      value: '[PULSA AWSD PARA MOVERTE]'
      objectReference: {fileID: 0}
    m_RemovedComponents: []
    m_RemovedGameObjects: []
    m_AddedGameObjects: []
    m_AddedComponents: []
  m_SourcePrefab: {fileID: 100100000, guid: db6828e52ecdccc4db2f84ba46e55a4f, type: 3}
