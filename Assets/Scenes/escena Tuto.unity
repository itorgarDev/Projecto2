    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: name
      value: Maogo, el atrapado
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.size
      value: 4
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[0]
      value: "\xA1Estoy hasta las narices de tanta monoton\xEDa!"
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[1]
      value: "\xA1Quiero viajar por el mundo! Llevo a\xF1os sin salir de esta villa."
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[2]
      value: 'Pero tengo miedo de una cosa: pasar por delante de la casa de Maola.'
      objectReference: {fileID: 0}
    - target: {fileID: 5604646733267574496, guid: db6828e52ecdccc4db2f84ba46e55a4f,
        type: 3}
      propertyPath: message.Array.data[3]
      value: "\xBFY si le piso lo barrido? \xA1Me partir\xEDa la escoba en la cabeza!"
      objectReference: {fileID: 0}
